# Copy to `.env` (gitignored) and edit. Values here are LOCAL DEV ONLY.
# Never reuse these in any shared, staging, or production environment.

# Postgres container
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres

# EHRbase DB roles
EHRBASE_DB_USER=ehrbase
EHRBASE_DB_PASSWORD=ehrbase
EHRBASE_DB_ADMIN_USER=ehrbase_admin
EHRBASE_DB_ADMIN_PASSWORD=ehrbase_admin

# EHRbase REST auth (BASIC)
EHRBASE_PORT=8080
EHRBASE_USER=ehrbase
EHRBASE_PASSWORD=ehrbase
EHRBASE_ADMIN_USER=ehrbase_admin
EHRBASE_ADMIN_PASSWORD=ehrbase_admin

# Keycloak (reserved for Phase 2; unused today)
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
