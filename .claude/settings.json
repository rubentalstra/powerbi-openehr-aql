{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)",
      "Bash(docker compose up -d)",
      "Bash(docker compose down *)",
      "Bash(mkdocs serve)",
      "Bash(mkdocs build)",
      "Bash(mkdocs gh-deploy *)",
      "Bash(bash dev/scripts/*.sh)",
      "Bash(pwsh -File dev/scripts/*.ps1)",
      "Bash(gh workflow run *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(jq *)"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)"
    ]
  }
}
